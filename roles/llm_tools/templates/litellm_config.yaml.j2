{% set local_llms_enabled = llamaswap_enabled | default(true) | bool %}
{% set remote_alias = model_group_alias['home-remote'] %}
{% set disabled_model_group_alias = {
  'home': remote_alias,
  'home-fast': remote_alias,
  'home-smart': remote_alias,
  'home-vision': remote_alias,
  'home-ha': remote_alias,
  'home-hermes': remote_alias,
  'home-embed': remote_alias,
  'home-remote': remote_alias
} %}
model_list:
{% if local_llms_enabled %}
  # Local models via llama-swap - base models and behavioral variants
  {% for model in llamaswap_models -%}
  # Base model
  - model_name: {{ model.alias }}
    litellm_params:
      model: "{{ model.litellm_provider | default('openai') }}/{{ model.alias }}"
      api_base: "http://{{ llm_inference_host }}:{{ llamaswap_port }}/v1"
      api_key: "llama-swap"
{% if model.allowed_openai_params is defined %}
      allowed_openai_params: {{ model.allowed_openai_params }}
{% endif %}
{% if model.encoding_format is defined %}
      encoding_format: {{ model.encoding_format }}
{% endif %}
    model_info:
      supports_function_calling: {{ model.supports_function_calling | lower }}
      supports_vision: {{ model.supports_vision | lower }}
{% if model.mode is defined %}
      mode: {{ model.mode }}
{% endif %}
{% if model.supports_reasoning is defined %}
      supports_reasoning: {{ model.supports_reasoning | lower }}
{% endif %}
{% if model.context_window is defined %}
      context_window: {{ model.context_window }}
      max_context_tokens: {{ model.context_window }}
{% endif %}
{% if model.max_input_tokens is defined %}
      max_input_tokens: {{ model.max_input_tokens }}
{% endif %}
{% if model.max_output_tokens is defined %}
      max_output_tokens: {{ model.max_output_tokens }}
{% endif %}

  # Explicit behavioral variants (currently only nothink)
  {% if model.variants is defined -%}
  {% for variant_name, variant_params in model.variants.items() -%}
  - model_name: {{ model.alias }}-{{ variant_name }}
    litellm_params:
      model: "{{ model.litellm_provider | default('openai') }}/{{ model.alias }}"
      api_base: "http://{{ llm_inference_host }}:{{ llamaswap_port }}/v1"
      api_key: "llama-swap"
      {% if model.allowed_openai_params is defined -%}
      allowed_openai_params: {{ model.allowed_openai_params }}
      {% endif -%}
      {{ variant_params | to_nice_yaml(indent=2) | indent(6, false) }}
    model_info:
      supports_function_calling: {{ model.supports_function_calling | lower }}
      supports_vision: {{ model.supports_vision | lower }}
{% if model.mode is defined %}
      mode: {{ model.mode }}
{% endif %}
{% if model.supports_reasoning is defined %}
      supports_reasoning: {{ model.supports_reasoning | lower }}
{% endif %}
{% if model.context_window is defined %}
      context_window: {{ model.context_window }}
      max_context_tokens: {{ model.context_window }}
{% endif %}
{% if model.max_input_tokens is defined %}
      max_input_tokens: {{ model.max_input_tokens }}
{% endif %}
{% if model.max_output_tokens is defined %}
      max_output_tokens: {{ model.max_output_tokens }}
{% endif %}
  {% endfor %}
  {% endif %}

  {% endfor %}
{% endif %}

  # OpenRouter models
{% if openrouter_models is defined %}
{% for model in openrouter_models %}
  - model_name: {{ model }}
    litellm_params:
      model: "openrouter/{{ model }}"
      api_key: "os.environ/OPENROUTER_API_KEY"
{% endfor %}
{% endif %}

  # Extra provider models
{% for model in litellm_extra_models %}
  - model_name: {{ model.model_name }}
    litellm_params:
{{ model.litellm_params | to_nice_yaml(indent=6, sort_keys=False, width=1000) | indent(6, true) }}
{% if model.model_info is defined %}
    model_info:
{{ model.model_info | to_nice_yaml(indent=6, sort_keys=False, width=1000) | indent(6, true) }}
{% endif %}
{% endfor %}

  # Wildcard for other providers
  - model_name: "*"
    litellm_params:
      model: "*"

router_settings:
  model_group_alias:
{{ (model_group_alias if local_llms_enabled else disabled_model_group_alias) | to_nice_yaml(indent=2) | indent(4, true) }}
  # Fallback from home to home-remote when local model fails
  fallbacks: {{ litellm_fallbacks if local_llms_enabled else [] }}
  redis_host: "{{ litellm_redis_container_name }}"
  redis_port: "{{ litellm_redis_port_container }}"

litellm_settings:
  drop_params: true
  master_key: "{{ litellm_master_key }}"
  cache: true
  cache_params:
    type: redis
    host: "{{ litellm_redis_container_name }}"
    port: "{{ litellm_redis_port_container }}"
  callbacks: ["arize_phoenix"]
  drop_params: true

mcp_servers:
{% for server_name, server in litellm_mcp_servers.items() %}
  {{ server_name }}:
{{ (server | dict2items | rejectattr('key', 'equalto', 'install') | items2dict) | to_nice_yaml(indent=4, sort_keys=False, width=1000) | indent(4, true) }}
{% endfor %}
general_settings:
  store_model_in_db: true
  store_prompts_in_spend_logs: false
