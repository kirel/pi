FROM {{ litellm_proxy_image }}

RUN if command -v apt-get >/dev/null 2>&1; then \
        apt-get update \
        && apt-get install -y --no-install-recommends git \
        && rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
        apk add --no-cache git; \
    else \
        echo "No supported package manager found to install git" >&2; \
        exit 1; \
    fi

# Install uv/uvx for Python-based MCP stdio servers (ha-mcp, fetch)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Install npm/npx for Node.js-based MCP stdio servers (tavily, n8n, notion).
# Some LiteLLM base images ship node without npm/npx.
RUN if ! command -v npx >/dev/null 2>&1; then \
        if command -v apt-get >/dev/null 2>&1; then \
            apt-get update \
            && apt-get install -y --no-install-recommends npm \
            && rm -rf /var/lib/apt/lists/*; \
        elif command -v apk >/dev/null 2>&1; then \
            apk add --no-cache npm; \
        else \
            echo "No supported package manager found to install npm/npx" >&2; \
            exit 1; \
        fi; \
    fi

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_TOOL_BIN_DIR=/usr/local/bin \
    PATH="/usr/local/bin:$PATH"

# Preinstall stdio MCP server packages so LiteLLM does not time out while
# package managers download tools during MCP discovery. The package lists are
# derived from litellm_mcp_servers in roles/llm_tools/defaults/main.yml.
{% set npm_packages = [] %}
{% for _name, server in litellm_mcp_servers.items() %}
{% if server.install is defined and server.install.manager == 'npm' %}
{% set _ = npm_packages.append(server.install.package) %}
{% endif %}
{% endfor %}
{% if npm_packages | length > 0 %}
RUN npm install -g {{ npm_packages | join(' ') }}
{% endif %}
{% for _name, server in litellm_mcp_servers.items() %}
{% if server.install is defined and server.install.manager == 'uv' %}
RUN uv tool install {{ server.install.args | join(' ') }}
{% endif %}
{% endfor %}
