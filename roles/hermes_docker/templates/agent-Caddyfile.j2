{
    email {{ hermes_docker_agent_caddy_email }}
    admin {{ hermes_docker_agent_caddy_admin }}

    log default {
        output file /var/log/caddy/caddy.log {
            roll_size 10MiB
            roll_keep 5
            roll_keep_for 168h
        }
        format console
    }
}

(tls_regfish) {
    tls {
        dns regfish {env.REGFISH_TOKEN}
    }
}

*.{{ agent_name }}.{{ hermes_docker_agent_domain_suffix }} {
    import tls_regfish

    @dashboard host {{ hermes_docker_agent_caddy_dashboard_subdomain }}.{{ agent_name }}.{{ hermes_docker_agent_domain_suffix }}
    handle @dashboard {
        reverse_proxy 127.0.0.1:{{ hermes_dashboard_container_port }} {
            header_up Host 127.0.0.1
        }
    }
{% if agent_name in hermes_docker_webui_agent_names %}

    @webui host webui.{{ agent_name }}.{{ hermes_docker_agent_domain_suffix }}
    handle @webui {
        reverse_proxy 127.0.0.1:{{ hermes_docker_webui_container_port }}
    }
{% endif %}

    import {{ hermes_docker_agent_caddy_sites_dir }}/*.caddy

    handle {
        respond "No route configured for {host}" 404
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10MiB
            roll_keep 10
            roll_keep_for 168h
        }
        format console
    }
}
