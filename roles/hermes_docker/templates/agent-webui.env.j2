# Generated by Ansible. Do not edit manually.
HERMES_WEBUI_HOST="0.0.0.0"
HERMES_WEBUI_PORT={{ hermes_docker_webui_container_port | to_json }}
HERMES_HOME={{ hermes_docker_webui_home_dir | to_json }}
HERMES_WEBUI_STATE_DIR={{ hermes_docker_webui_state_dir | to_json }}
HERMES_WEBUI_AGENT_DIR={{ hermes_docker_webui_agent_dir | to_json }}
HERMES_WEBUI_PYTHON={{ hermes_docker_webui_python | to_json }}
HERMES_WEBUI_AUTO_INSTALL={{ (hermes_docker_webui_auto_install | bool) | ternary('"1"', '"0"') }}
HERMES_WEBUI_CHAT_BACKEND={{ hermes_docker_webui_chat_backend | to_json }}
HERMES_WEBUI_DEFAULT_WORKSPACE={{ hermes_docker_webui_workspace_dir | to_json }}
WANTED_UID={{ hermes_docker_data_uid | to_json }}
WANTED_GID={{ hermes_docker_data_gid | to_json }}
HERMES_SKIP_CHMOD="1"
{% set webui_inherited_env = hermes_docker_effective_global_env | combine(hermes_docker_agents_env.get(agent_name, {}), recursive=True) | combine(hermes_docker_agents_env_secret.get(agent_name, {}), recursive=True) %}
{% for key in hermes_docker_webui_inherit_env_keys | sort %}
{% if webui_inherited_env[key] is defined and webui_inherited_env[key] | string | length > 0 %}
{{ key }}={{ webui_inherited_env[key] | to_json }}
{% endif %}
{% endfor %}
{% if hermes_docker_webui_password | string | length > 0 %}
HERMES_WEBUI_PASSWORD={{ hermes_docker_webui_password | to_json }}
{% endif %}
{% if hermes_docker_tailscale_enabled | bool %}
HERMES_API_URL="http://127.0.0.1:{{ hermes_gateway_container_port }}"
HERMES_WEBUI_GATEWAY_BASE_URL="http://127.0.0.1:{{ hermes_gateway_container_port }}"
{% else %}
HERMES_API_URL="http://hermes-{{ agent_name }}:{{ hermes_gateway_container_port }}"
HERMES_WEBUI_GATEWAY_BASE_URL="http://hermes-{{ agent_name }}:{{ hermes_gateway_container_port }}"
{% endif %}
