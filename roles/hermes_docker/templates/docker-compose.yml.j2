---
x-hermes-logging: &hermes-logging
  driver: json-file
  options:
    max-size: {{ hermes_docker_log_max_size | string | to_json }}
    max-file: {{ hermes_docker_log_max_files | string | to_json }}

services:
{% for agent_name in hermes_docker_effective_agent_names %}
{% set agent_env = hermes_docker_agents_env.get(agent_name, {}) | combine(hermes_docker_agents_env_secret.get(agent_name, {}), recursive=True) %}
{% set agent_index = loop.index0 %}
{% if hermes_docker_tailscale_enabled | bool %}
  ts-hermes-{{ agent_name }}:
    image: {{ hermes_docker_tailscale_image }}
    container_name: ts-hermes-{{ agent_name }}
    hostname: {{ hermes_docker_tailscale_hostname_prefix }}-{{ agent_name }}
    restart: {{ hermes_docker_restart_policy }}
    logging: *hermes-logging
    env_file:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/tailscale.env
    volumes:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/tailscale:{{ hermes_docker_tailscale_state_dir }}
    devices:
      - /dev/net/tun:/dev/net/tun
    cap_add:
      - net_admin
      - sys_module
{% if hermes_docker_tailscale_healthcheck_enabled | bool %}
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          tailscale status --json | grep -q '"BackendState": "Running"'
      interval: {{ hermes_docker_tailscale_healthcheck_interval }}
      timeout: {{ hermes_docker_tailscale_healthcheck_timeout }}
      retries: {{ hermes_docker_tailscale_healthcheck_retries }}
      start_period: {{ hermes_docker_tailscale_healthcheck_start_period }}
{% endif %}
{% if hermes_docker_isolate_agents | bool %}
    extra_hosts:
{% for host_entry in hermes_docker_agent_extra_hosts[agent_name] %}
      - {{ host_entry | to_json }}
{% endfor %}
    dns:
{% for dns_server in hermes_docker_dns_servers %}
      - {{ dns_server | to_json }}
{% endfor %}
{% endif %}
    networks:
{% if hermes_docker_isolate_agents | bool %}
      - {{ hermes_docker_agent_networks[agent_name].name }}
{% else %}
      - {{ hermes_docker_network_name }}
{% endif %}
{% endif %}
  hermes-{{ agent_name }}:
    image: {{ hermes_docker_image }}
{% if hermes_docker_build_enabled | bool %}
    build:
      context: {{ hermes_docker_base_dir }}/hermes-image
      args:
        HERMES_BASE_IMAGE: {{ hermes_docker_base_image }}
{% endif %}
    pull_policy: {{ hermes_docker_pull_policy }}
    container_name: hermes-{{ agent_name }}
    restart: {{ hermes_docker_restart_policy }}
    logging: *hermes-logging
{% if hermes_docker_tailscale_enabled | bool %}
    network_mode: service:ts-hermes-{{ agent_name }}
    depends_on:
      - ts-hermes-{{ agent_name }}
{% endif %}
{% if hermes_docker_command is string %}
    command: {{ hermes_docker_command }}
{% else %}
    command:
{% for item in hermes_docker_command %}
      - {{ item | string | to_json }}
{% endfor %}
{% endif %}
    shm_size: {{ hermes_docker_shm_size }}
    env_file:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/data/.env
{% if not (hermes_docker_tailscale_enabled | bool) %}
    ports:
      - "{{ (hermes_dashboard_bind_address | default('') | string | length > 0) | ternary((hermes_dashboard_bind_address | string) ~ ':', '') }}{{ hermes_dashboard_base_port | int + agent_index }}:{{ hermes_dashboard_container_port }}"
{% if hermes_publish_gateway_api | bool %}
      - "{{ (hermes_gateway_bind_address | default('') | string | length > 0) | ternary((hermes_gateway_bind_address | string) ~ ':', '') }}{{ hermes_gateway_base_port | int + agent_index }}:{{ hermes_gateway_container_port }}"
{% endif %}
{% if agent_env.API_SERVER_ENABLED | default(false) | bool %}
{% set api_server_port = agent_env.API_SERVER_PORT | default(hermes_gateway_container_port) %}
      - "{{ (hermes_gateway_bind_address | default('') | string | length > 0) | ternary((hermes_gateway_bind_address | string) ~ ':', '') }}{{ api_server_port }}:{{ api_server_port }}"
{% endif %}
{% endif %}
    volumes:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/data:{{ hermes_container_data_dir }}
{% if agent_name in hermes_docker_webui_agent_names %}
      - hermes-agent-src-{{ agent_name }}:/opt/hermes
{% endif %}
{% set agent_workspace_host_dir = hermes_docker_webui_effective_workspace_host_dirs.get(agent_name, '') %}
{% if agent_workspace_host_dir | string | length > 0 %}
      - {{ agent_workspace_host_dir }}:{{ hermes_docker_webui_workspace_dir }}
{% endif %}
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/supervisor/supervisord.conf:/etc/supervisor/supervisord.conf:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/supervisor/conf.d:{{ hermes_container_data_dir }}/supervisor/conf.d
{% if hermes_docker_agent_caddy_enabled | bool %}
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/sites:{{ hermes_docker_agent_caddy_sites_dir }}
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/static:{{ hermes_docker_agent_caddy_static_dir }}
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/logs:/var/log/caddy:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/skills/caddy-proxy:{{ hermes_docker_agent_caddy_skill_dir }}:ro
{% endif %}
{% for skill_dir in hermes_docker_agents_external_skill_dirs.get(agent_name, []) %}
      - {{ skill_dir.host_dir }}:{{ skill_dir.container_dir }}:ro
{% endfor %}
{% if not (hermes_docker_tailscale_enabled | bool) %}
{% if hermes_docker_isolate_agents | bool %}
    extra_hosts:
{% for host_entry in hermes_docker_agent_extra_hosts[agent_name] %}
      - {{ host_entry | to_json }}
{% endfor %}
    dns:
{% for dns_server in hermes_docker_dns_servers %}
      - {{ dns_server | to_json }}
{% endfor %}
{% endif %}
    networks:
{% if hermes_docker_isolate_agents | bool %}
      - {{ hermes_docker_agent_networks[agent_name].name }}
{% else %}
      - {{ hermes_docker_network_name }}
{% endif %}
{% endif %}
{% if hermes_docker_agent_caddy_enabled | bool %}
  caddy-hermes-{{ agent_name }}:
    image: {{ hermes_docker_agent_caddy_image }}
    pull_policy: build
    build:
      context: {{ hermes_docker_base_dir }}/caddy-image
    container_name: caddy-hermes-{{ agent_name }}
    restart: {{ hermes_docker_restart_policy }}
    logging: *hermes-logging
    network_mode: service:ts-hermes-{{ agent_name }}
    depends_on:
      - ts-hermes-{{ agent_name }}
      - hermes-{{ agent_name }}
    env_file:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/caddy.env
    command:
      - caddy
      - run
      - --watch
      - --config
      - /etc/caddy/Caddyfile
      - --adapter
      - caddyfile
    volumes:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/sites:{{ hermes_docker_agent_caddy_sites_dir }}:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/static:{{ hermes_docker_agent_caddy_static_dir }}:ro
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/logs:/var/log/caddy
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/data:/data
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/caddy/config:/config
{% endif %}
{% if agent_name in hermes_docker_webui_agent_names %}
  webui-hermes-{{ agent_name }}:
    image: {{ hermes_docker_webui_image }}
    container_name: webui-hermes-{{ agent_name }}
    restart: {{ hermes_docker_restart_policy }}
    logging: *hermes-logging
    env_file:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/webui.env
{% if hermes_docker_tailscale_enabled | bool %}
    network_mode: service:ts-hermes-{{ agent_name }}
    depends_on:
      - ts-hermes-{{ agent_name }}
      - hermes-{{ agent_name }}
{% else %}
    ports:
      - "{{ (hermes_docker_webui_bind_address | default('') | string | length > 0) | ternary((hermes_docker_webui_bind_address | string) ~ ':', '') }}{{ hermes_docker_webui_base_port | int + agent_index }}:{{ hermes_docker_webui_container_port }}"
    depends_on:
      - hermes-{{ agent_name }}
{% if hermes_docker_isolate_agents | bool %}
    extra_hosts:
{% for host_entry in hermes_docker_agent_extra_hosts[agent_name] %}
      - {{ host_entry | to_json }}
{% endfor %}
    dns:
{% for dns_server in hermes_docker_dns_servers %}
      - {{ dns_server | to_json }}
{% endfor %}
{% endif %}
    networks:
{% if hermes_docker_isolate_agents | bool %}
      - {{ hermes_docker_agent_networks[agent_name].name }}
{% else %}
      - {{ hermes_docker_network_name }}
{% endif %}
{% endif %}
    volumes:
      - {{ hermes_docker_base_dir }}/{{ agent_name }}/data:{{ hermes_docker_webui_home_dir }}
      - hermes-agent-src-{{ agent_name }}:{{ hermes_docker_webui_agent_dir }}:ro
{% set webui_workspace_host_dir = hermes_docker_webui_effective_workspace_host_dirs.get(agent_name, '') %}
{% if webui_workspace_host_dir | string | length > 0 %}
      - {{ webui_workspace_host_dir }}:{{ hermes_docker_webui_workspace_dir }}
{% endif %}
{% endif %}
{% endfor %}

networks:
{% if hermes_docker_isolate_agents | bool %}
{% for agent_name in hermes_docker_effective_agent_names %}
  {{ hermes_docker_agent_networks[agent_name].name }}:
    driver: bridge
    ipam:
      config:
        - subnet: {{ hermes_docker_agent_networks[agent_name].subnet }}
{% endfor %}
{% else %}
  {{ hermes_docker_network_name }}:
    driver: bridge
{% endif %}
{% if hermes_docker_webui_agent_names | length > 0 %}

volumes:
{% for agent_name in hermes_docker_webui_agent_names %}
  hermes-agent-src-{{ agent_name }}:
{% endfor %}
{% endif %}
