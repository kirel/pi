{
        email danishkirel@gmail.com
        order wake_on_lan before respond
        log {
                output stdout
        }
}

(internal_only) {
        @denied not remote_ip 192.168.0.0/16 172.16.0.0/12 10.0.0.0/8 127.0.0.1 ::1
        abort @denied
}

danishkirel.asuscomm.com {
        reverse_proxy {{ homelab_nuc_ip }}:{{ homeassistant_http_port }}
        log
}

{% for service, props in services.items() %}
{% if props.tls_skip | default(false) %}http://{% endif %}{{ props.domain|default(service ~ ".lan") }}{% if props.proxy_port is defined %}:{{ props.proxy_port }}{% endif %} {
{% if service == "proxmox" %}
        # Special Proxmox configuration with HTTPS proxying
        import internal_only
        reverse_proxy https://{{ props.target }}:{{ props.http_port }} {
                transport http {
                        tls_server_name {{ props.domain | default(service ~ ".lan") }}
                        tls_insecure_skip_verify
                }
                header_up Host {host}
                header_up X-Real-IP {remote}
                header_up X-Forwarded-For {remote}
                header_up X-Forwarded-Proto {scheme}
        }
        tls internal
{% else %}
        # Use localhost if the target is the current host (homelab-nuc)
        {% set target_host = (props.target | regex_replace('\\.lan$', '')) if props.target.endswith('.lan') else props.target %}
        {% set backend_host = 'localhost' if target_host == 'homelab-nuc' else props.target %}
        reverse_proxy {% if props.tls_skip | default(false) %}http://{% endif %}{{ backend_host }}:{{ props.http_port }} {
                {% if service == 'metamcp' %}
                header_up Connection "keep-alive"
                header_up Upgrade {>Upgrade}
                header_up X-Accel-Buffering no
                flush_interval -1
                {% endif %}
        }
        {% set domain = props.domain | default(service ~ ".lan") %}
        {% if not props.public | default(false) %}
        import internal_only
        {% endif %}
        {% if not props.tls_skip | default(false) %}
            {% if domain.endswith(".kirelabs.org") %}
        tls {
            dns regfish {env.REGFISH_TOKEN}
        }
            {% elif domain.endswith(".lan") or props.force_tls_internal | default(false) %}
        tls internal
            {% endif %}
        {% endif %}
        {% if props.wol is defined %}
        handle_errors {
                @502 expression {err.status_code} == 502
                handle @502 {
                        # Add custom fields to the log entry generated when this error handler runs
                        log_append wol_triggered "true"
                        log_append wol_target "{{ backend_host }}"
                        log_append wol_mac "{{ props.wol }}"
                        log_append wol_triggering_request "{http.request.method} {http.request.uri} from {http.request.remote.ip}"
                        log_append wol_error_status "{err.status_code}"

                        wake_on_lan {{ props.wol }} # MAC address from service definition
                        reverse_proxy {% if props.tls_skip | default(false) %}http://{% endif %}{{ backend_host }}:{{ props.http_port }} {
                                lb_try_duration {{ props.try | default('60s') }}
                        }
                }
        }
        {% endif %}
{% endif %}
        log
}
{% endfor %}
