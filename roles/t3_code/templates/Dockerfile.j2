FROM ghcr.io/astral-sh/uv:latest AS uv

FROM {{ t3_code_node_image }}

COPY --from=uv /uv /uvx /usr/local/bin/

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        dnsutils \
        fd-find \
        git \
        jq \
        less \
        lsof \
        netcat-openbsd \
        openssh-client \
        ripgrep \
        rsync \
        tree \
    && usermod --home {{ t3_code_home_container_path }} node \
    && ln -s /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
    t3@{{ t3_code_version }} \
    {{ t3_code_codex_package }}

# T3 Code only exposes project actions below its phone breakpoint. Keep the
# action tappable on wider touch devices such as an iPad in landscape.
COPY touch-device-fixes.css /tmp/t3-code-touch-device-fixes.css

RUN t3_client_dir="$(npm root -g)/t3/dist/client" \
    && cp /tmp/t3-code-touch-device-fixes.css "$t3_client_dir/touch-device-fixes.css" \
    && sed -i 's#</head>#<link rel="stylesheet" href="/touch-device-fixes.css"></head>#' "$t3_client_dir/index.html"
