FROM ghcr.io/astral-sh/uv:latest AS uv

FROM {{ t3_code_node_image }}

COPY --from=uv /uv /uvx /usr/local/bin/

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        dnsutils \
        fd-find \
        git \
        jq \
        less \
        lsof \
        netcat-openbsd \
        openssh-client \
        ripgrep \
        rsync \
        tree \
    && usermod --home {{ t3_code_home_container_path }} node \
    && ln -s /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
    t3@{{ t3_code_version }} \
    {{ t3_code_codex_package }}
