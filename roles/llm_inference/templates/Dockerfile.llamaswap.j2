FROM ghcr.io/mostlygeek/llama-swap:cuda

USER root

# The upstream image doesn't persist UID 10001 in /etc/passwd, which breaks
# some tooling that calls getpass.getuser(). Add an entry and ensure a writable
# home/cache for llama.cpp/Hugging Face downloads.
RUN getent passwd 10001 >/dev/null || echo 'app:x:10001:10001::/app:/bin/bash' >> /etc/passwd \
 && getent group 10001 >/dev/null || echo 'app:x:10001:' >> /etc/group \
 && mkdir -p /app/.cache \
 && chown -R 10001:10001 /app

ENV HOME=/app

# Drop back to the upstream image's non-root user.
USER 10001:10001
